# Knowledge Base service configuration (env prefix: KB_)
KB_DATABASE_URL=postgresql+asyncpg://kb:kb@db:5432/kb
KB_APP_NAME=SurfWise-Compatible Knowledge Base
KB_PUBLIC_BASE_URL=http://localhost:8080
# Default API token seeded on first run (BookStack "Token id:secret" auth).
# Point SurfWise's BookStack connector at this service using these values.
KB_DEFAULT_TOKEN_ID=kb_demo_token_id
KB_DEFAULT_TOKEN_SECRET=kb_demo_token_secret
KB_DEFAULT_TOKEN_NAME=default-demo-token
KB_SEED_ON_STARTUP=true
KB_LOG_LEVEL=INFO
